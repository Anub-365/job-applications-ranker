# ╔══════════════════════════════════════════════════════════════╗
# ║         Internship Connect — Environment Variables          ║
# ╚══════════════════════════════════════════════════════════════╝
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────
# PostgreSQL with pgvector extension required.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/internship_connect

# ── Authentication ────────────────────────────────────────────
# Generate a strong random key:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production-use-a-strong-random-key

# ── OpenAI (Primary LLM for resume parsing) ──────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── GitHub (Profile analysis) ────────────────────────────────
# Create a PAT at: https://github.com/settings/tokens
# Required scopes: public_repo (read-only access to public repos)
GITHUB_TOKEN=ghp_your-github-personal-access-token

# ── Google Gemini (LLM fallback #2) ──────────────────────────
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Groq (LLM fallback #1 — fastest) ────────────────────────
# Get your keys at: https://console.groq.com/keys
# Multiple keys enable automatic rotation on rate limits.
GROQ_API_KEY_1=gsk_your-groq-api-key-1
GROQ_API_KEY_2=gsk_your-groq-api-key-2
GROQ_API_KEY_3=gsk_your-groq-api-key-3
